# Copy to .env and fill in. Never commit .env.
# Without VERTEX_PROJECT_ID, the app runs in retrieval-only mode (still fully functional, no LLM phrasing).

# Vertex AI / Gemini
VERTEX_PROJECT_ID=your-gcp-project-id
VERTEX_LOCATION=global
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# Optional: override the copilot model (default: gemini-3.5-flash; needs VERTEX_LOCATION=global)
COPILOT_MODEL=gemini-3.5-flash
